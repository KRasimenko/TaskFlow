@startuml use_case
skinparam shadowing false
skinparam defaultFontName "DejaVu Sans"
skinparam dpi 130

title Диаграмма прецедентов - TaskFlow

left to right direction

actor "Пользователь" as User

rectangle "TaskFlow" {
  usecase "Войти в систему" as UC1
  usecase "Зарегистрироваться" as UC2
  usecase "Просмотреть задачи" as UC3
  usecase "Поиск и фильтрация" as UC4
  usecase "Создать задачу" as UC5
  usecase "Редактировать задачу" as UC6
  usecase "Удалить задачу" as UC7
  usecase "Избранное" as UC8
  usecase "Изменить статус" as UC9
  usecase "Календарь" as UC10
  usecase "Уведомления" as UC11
  usecase "Профиль" as UC12
  usecase "Выход" as UC13
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC7
User --> UC8
User --> UC9
User --> UC10
User --> UC11
User --> UC12
User --> UC13

UC5 ..> UC3 : <<include>>
UC6 ..> UC3 : <<include>>
UC7 ..> UC3 : <<include>>
UC4 ..> UC3 : <<extend>>
UC9 ..> UC6 : <<extend>>
UC8 ..> UC6 : <<extend>>

@enduml
